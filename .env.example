# --- PostgreSQL Configuration (Example values) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=trada_db

# --- Backend Configuration ---
# 'db' refers to the database service name in docker-compose.yml
DATABASE_URL=postgresql://admin:your_secure_password@db:5432/trada_db

# --- Security (JWT) ---
# Generate a real secret with: openssl rand -hex 32
SECRET_KEY=replace_this_with_a_long_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30