# ==============================================================================
# TRADA API - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# INSTRUCTIONS: 
# 1. Copy this file and rename it to '.env'
# 2. Replace the placeholder values (your_...) with your actual local/prod values.
# 3. NEVER COMMIT your real '.env' file to version control.
# ==============================================================================

# --- DATABASE CONFIGURATION (PostgreSQL) ---
# Used by the 'db' service in docker-compose.yml
POSTGRES_USER=your_postgres_user_here
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=your_database_name_here

# Connection string for FastAPI (Note: 'db' is the hostname inside Docker)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://your_postgres_user_here:your_secure_postgres_password_here@db:5432/your_database_name_here

# --- SECURITY & AUTHENTICATION (JWT) ---
# Secret key generated for HS256 algorithm (256-bit entropy)
# TIP: Generate a secure key in your terminal using: openssl rand -hex 32
# OR in Python using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_a_32_byte_hex_string_for_security
ALGORITHM=HS256

# Standard DevSecOps Token Lifespans
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- HARDENING & SESSION MANAGEMENT ---
# Duration for which the refresh token remains valid
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- KMP DEVELOPMENT BRIDGE ---
# Android Emulator uses 10.0.2.2 to access the host's localhost
KMP_API_URL_ANDROID=http://10.0.2.2:8000
# iOS Simulator or Web can use the standard localhost
KMP_API_URL_IOS=http://localhost:8000